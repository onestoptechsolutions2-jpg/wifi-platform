# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://wifiuser:password@localhost:5432/wifiplatform"

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── App ───────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
API_BASE_URL="http://localhost:3000"

# Dashboard & Admin origins (comma-separated for CORS)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string-in-production"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# ── Encryption (AES-256 for hardware credentials) ─────────────────────────
ENCRYPTION_KEY="32-char-hex-key-change-in-production!!"

# ── SMS — Twilio ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# ── SMS — Africa's Talking (fallback) ────────────────────────────────────
AT_API_KEY="your_africas_talking_api_key"
AT_USERNAME="sandbox"

# ── Email — SendGrid ──────────────────────────────────────────────────────
SENDGRID_API_KEY="SG.xxxxxxxx"
EMAIL_FROM="noreply@yourplatform.com"
EMAIL_FROM_NAME="WiFi Platform"

# ── OAuth — Google ────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── OAuth — Facebook ──────────────────────────────────────────────────────
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# ── File Storage — Cloudflare R2 ──────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="wifi-platform-assets"
R2_PUBLIC_URL="https://assets.yourplatform.com"

# ── Super Admin ───────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL="admin@yourplatform.com"
SUPER_ADMIN_PASSWORD="change-me-on-first-login"
