generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────

enum TenantStatus {
  trial
  active
  suspended
}

enum LoginMethod {
  email
  phone
  google
  facebook
  clickthrough
}

enum SessionStatus {
  active
  expired
  revoked
}

enum CampaignType {
  email
  sms
}

enum CampaignStatus {
  draft
  sending
  sent
  failed
}

enum PaymentGateway {
  stripe
  paystack
  flutterwave
  mpesa
  pesapal
  manual
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum UserRole {
  super_admin
  client_admin
}

// ── Models ────────────────────────────────────────────────────────────────

model Tenant {
  id        String       @id @default(uuid())
  name      String
  domain    String       @unique   // e.g. wifi.javacafe.com
  plan      String       @default("starter")
  status    TenantStatus @default(trial)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  // Branding
  logoUrl      String?  @map("logo_url")
  primaryColor String   @default("#1B5FAD") @map("primary_color")
  bgColor      String   @default("#FFFFFF") @map("bg_color")
  headline     String   @default("Welcome! Connect to free WiFi")
  subheadline  String   @default("Enter your details to get online")
  redirectUrl  String   @default("https://google.com") @map("redirect_url")
  sessionHours Int      @default(4) @map("session_hours")
  termsText    String   @default("I agree to the terms and privacy policy") @map("terms_text")

  // Login method toggles
  loginEmail        Boolean @default(true)  @map("login_email")
  loginPhone        Boolean @default(false) @map("login_phone")
  loginGoogle       Boolean @default(false) @map("login_google")
  loginFacebook     Boolean @default(false) @map("login_facebook")
  loginClickthrough Boolean @default(true)  @map("login_clickthrough")

  // Hardware vendor — mikrotik | unifi | omada | openwrt | radius | none
  vendorType   String  @default("mikrotik") @map("vendor_type")
  vendorConfig Json?   @map("vendor_config")  // vendor-specific credentials (passwords AES-256 encrypted)

  // MikroTik router credentials (password stored AES-256 encrypted)
  mkHost        String? @map("mk_host")         // IP or hostname
  mkPort        Int     @default(8728) @map("mk_port")
  mkUser        String? @map("mk_user")
  mkPasswordEnc String? @map("mk_password_enc") // AES-256 ciphertext
  mkInterface   String  @default("bridge") @map("mk_interface")

  // Billing
  billingEmail     String?        @map("billing_email")
  lastPaidAt       DateTime?      @map("last_paid_at")
  nextBillDate     DateTime?      @map("next_bill_date")
  billingGateway   String?        @map("billing_gateway")   // stripe | paystack | flutterwave | mpesa | pesapal
  stripeCustomerId String?        @map("stripe_customer_id")
  stripeSubId      String?        @map("stripe_sub_id")
  billingNotes     String?        @map("billing_notes")

  // Relations
  users     User[]
  customers Customer[]
  sessions  PortalSession[]
  campaigns Campaign[]
  payments  Payment[]

  @@map("tenants")
}

model User {
  id          String    @id @default(uuid())
  tenantId    String?   @map("tenant_id")  // null = super admin
  email       String    @unique
  password    String                        // bcrypt hash
  name        String
  role        UserRole  @default(client_admin)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Contact
  name          String?
  email         String?
  phone         String?           // E.164, e.g. +254712345678
  phoneVerified Boolean @default(false) @map("phone_verified")

  // Social login
  socialProvider String? @map("social_provider") // google | facebook
  socialId       String? @map("social_id")
  photoUrl       String? @map("photo_url")

  // Consent
  consentGiven Boolean     @default(false) @map("consent_given")
  loginMethod  LoginMethod @map("login_method")

  // Visit stats
  firstSeen  DateTime @default(now()) @map("first_seen")
  lastSeen   DateTime @default(now()) @map("last_seen")
  visitCount Int      @default(1) @map("visit_count")

  tags String[] @default([])

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  sessions PortalSession[]

  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@map("customers")
}

model PortalSession {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  customerId  String? @map("customer_id")

  macAddress  String        @map("mac_address")
  deviceType  String?       @map("device_type")  // mobile | desktop | tablet
  loginMethod LoginMethod   @map("login_method")
  status      SessionStatus @default(active)

  grantedAt       DateTime  @default(now()) @map("granted_at")
  expiresAt       DateTime  @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  durationMinutes Int?      @map("duration_minutes")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([tenantId, grantedAt])
  @@index([tenantId, macAddress])
  @@map("portal_sessions")
}

model Campaign {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  type    CampaignType
  status  CampaignStatus @default(draft)
  subject String?        // email only
  body    String         // email HTML or SMS text

  scheduledAt    DateTime? @map("scheduled_at")
  sentAt         DateTime? @map("sent_at")
  recipientCount Int       @default(0) @map("recipient_count")
  deliveredCount Int       @default(0) @map("delivered_count")
  failedCount    Int       @default(0) @map("failed_count")

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("campaigns")
}

model Payment {
  id        String         @id @default(uuid())
  tenantId  String         @map("tenant_id")
  amount    Float          // major currency unit (e.g. 99.00 USD, 12000 KES)
  currency  String         @default("USD")
  gateway   PaymentGateway
  reference String?        // gateway transaction / checkout ID
  status    PaymentStatus  @default(pending)
  plan      String
  paidAt    DateTime?      @map("paid_at")
  createdAt DateTime       @default(now()) @map("created_at")
  metadata  Json?          // gateway-specific payload

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("payments")
}

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  tenantId  String   @map("tenant_id")
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone, tenantId])
  @@map("otp_codes")
}

// Platform-wide settings (key/value store)
model PlatformSettings {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// Editable plan definitions — managed via super-admin /plans API
model PlanDefinition {
  key         String   @id                 // "starter" | "growth" | "pro"
  label       String
  price       Float
  currency    String   @default("USD")
  color       String   @default("#1B5FAD")
  accentColor String   @default("#EFF6FF") @map("accent_color")
  features    String[] @default([])
  missing     String[] @default([])
  isActive    Boolean  @default(true)      @map("is_active")
  sortOrder   Int      @default(0)         @map("sort_order")
  updatedAt   DateTime @updatedAt          @map("updated_at")

  @@map("plan_definitions")
}
